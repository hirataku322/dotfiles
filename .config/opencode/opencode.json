{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "npm *": "allow",
      "npx *": "allow",
      "bun *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "mkdir *": "allow",
      "cp *": "ask",
      "mv *": "ask",
      "rm *": "deny"
    },
    "edit": {
      "*": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "~/**": "ask"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
